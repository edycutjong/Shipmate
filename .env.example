# Supabase — Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub - Needed to analyze repository data (README, commit history, routes)
# Generate a classic token with read access here: https://github.com/settings/tokens/new
GITHUB_TOKEN=your-github-personal-access-token

# OpenAI - Needed to power the AI marketing asset generation agents
# Generate an API key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
